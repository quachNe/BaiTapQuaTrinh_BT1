<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- ===== FIXED HEADER ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chuyển Đổi Vàng"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#CFAE4F"
        android:gravity="center"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/txtDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tính giá trị vàng theo thời gian thực"
        android:textSize="18sp"
        android:textColor="#777777"
        android:gravity="center"
        android:layout_marginBottom="12dp"/>

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ==== CARD INPUT ==== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:padding="18dp"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:backgroundTint="#FFFFFF">

                <TextView
                    android:text="Loại vàng"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <Spinner
                    android:id="@+id/spinnerGoldType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingEnd="30dp"
                    style="@style/CustomSpinner"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:text="Đơn vị"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <Spinner
                    android:id="@+id/spinnerUnit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingEnd="30dp"
                    style="@style/CustomSpinner"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:text="Giá tiền / đơn vị (VND)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/edtPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:background="#F2F2F2"
                    android:padding="12dp"
                    android:textSize="20sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:text="Số lượng"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/edtAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:background="#F2F2F2"
                    android:padding="12dp"
                    android:textSize="20sp"
                    android:layout_marginBottom="16dp"/>

                <!-- ==== BUTTONS ==== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnReset"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Làm mới"
                        android:textStyle="bold"
                        android:backgroundTint="#B0B0B0"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnConvert"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Chuyển đổi"
                        android:textStyle="bold"
                        android:backgroundTint="#CFAE4F"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- RESULT -->
                <TextView
                    android:text="Kết quả"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginTop="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/txtResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 VND"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:background="#F9F9F9"
                    android:padding="14dp"/>
            </LinearLayout>

            <!-- ==== HISTORY ==== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Lịch sử chuyển đổi"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#444444"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/btnClearHistory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xóa"
                        android:textStyle="bold"
                        android:backgroundTint="#D9534F"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <!-- SCROLL HÀNG NGANG -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <!-- CHỈ 1 CHILD DUY NHẤT -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- HEADER -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="10dp"
                            android:background="#F9F4E7">

                            <TextView
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:text="#"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="140dp"
                                android:layout_height="wrap_content"
                                android:text="Thời gian"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="160dp"
                                android:layout_height="wrap_content"
                                android:text="Loại"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="120dp"
                                android:layout_height="wrap_content"
                                android:text="SL"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:text="Đơn vị"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="160dp"
                                android:layout_height="wrap_content"
                                android:text="Giá (VND)"
                                android:textSize="14sp"
                                android:gravity="center"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- LISTVIEW KHỚP CỘT VỚI HEADER -->
                        <ListView
                            android:id="@+id/listHistory"
                            android:layout_width="wrap_content"
                            android:layout_height="250dp"
                            android:divider="#ECECEC"
                            android:dividerHeight="1dp"/>
                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>


        </LinearLayout>
    </ScrollView>

</LinearLayout>