<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ===== FIXED HEADER ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chuyển đổi vàng"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/txtDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tính giá trị vàng theo thời gian thực"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginBottom="10dp"/>

    <!-- ===== SCROLL AREA ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:padding="16dp"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="4dp">

                <TextView
                    android:text="Loại vàng"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <Spinner
                    android:id="@+id/spinnerGoldType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingEnd="30dp"
                    style="@style/CustomSpinner"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:text="Đơn vị"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <Spinner
                    android:id="@+id/spinnerUnit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingEnd="30dp"
                    style="@style/CustomSpinner"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:text="Giá tiền / đơn vị (VND)"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/edtPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:background="#F1F1F1"
                    android:padding="10dp"
                    android:textSize="20sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:text="Số lượng"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <EditText
                    android:id="@+id/edtAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:background="#F1F1F1"
                    android:padding="10dp"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <!-- BUTTON -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnReset"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:text="Làm mới"
                        android:textStyle="bold"
                        android:backgroundTint="#9E9E9E"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnConvert"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:text="Chuyển đổi"
                        android:textStyle="bold"
                        android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- RESULT -->
                <TextView
                    android:text="Kết quả"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"/>

                <TextView
                    android:id="@+id/txtResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 VND"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:background="#F8F8F8"
                    android:padding="12dp"/>
            </LinearLayout>

            <!-- HISTORY CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="4dp"
                android:padding="10dp">

                <!-- TITLE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Lịch sử chuyển đổi"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/btnClearHistory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xóa"
                        android:backgroundTint="#D32F2F"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <!-- HEADER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:background="#EEEEEE">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="0.6"
                        android:layout_height="wrap_content"
                        android:text="#"
                        android:gravity="center"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1.2"
                        android:layout_height="wrap_content"
                        android:text="Thời gian"
                        android:gravity="center"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1.6"
                        android:layout_height="wrap_content"
                        android:text="Loại"
                        android:gravity="center"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1.6"
                        android:layout_height="wrap_content"
                        android:text="SL"
                        android:gravity="center"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Đơn vị"
                        android:gravity="center"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1.2"
                        android:layout_height="wrap_content"
                        android:text="Giá (VND)"
                        android:gravity="center"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- LIST -->
                <ListView
                    android:id="@+id/listHistory"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:divider="#EEEEEE"
                    android:dividerHeight="1dp"/>
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>