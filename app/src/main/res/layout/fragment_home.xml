<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="28dp">

        <!-- TIÊU ĐỀ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Giá Vàng Hôm Nay"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#CFAE4F"
            android:gravity="center"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="8dp"/>

        <!-- NGÀY -->
        <TextView
            android:id="@+id/txtDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- FILTER -->
        <Spinner
            android:id="@+id/spinnerFilter"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_spinner"
            android:paddingEnd="30dp"
            style="@style/CustomSpinner"
            android:layout_marginBottom="14dp"/>

        <!-- HEADER BẢNG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#F9F4E7">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1.3"
                android:layout_height="wrap_content"
                android:text="Loại vàng"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1.4"
                android:layout_height="wrap_content"
                android:text="Mua vào"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#1A1A1A"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1.4"
                android:layout_height="wrap_content"
                android:text="Bán ra"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#1A1A1A"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Ghi chú"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="#1A1A1A"/>
        </LinearLayout>

        <!-- LIST -->
        <ListView
            android:id="@+id/listGold"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#E0E0E0"
            android:dividerHeight="1dp"/>
    </LinearLayout>

    <!-- LOADING -->
    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:indeterminateTint="#FBC02D" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang tải dữ liệu..."
            android:textColor="#FBC02D"
            android:layout_marginTop="14dp"/>
    </LinearLayout>

</FrameLayout>